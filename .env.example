# ─── Backend API ──────────────────────────────────────────────────
# No local backend exists — the frontend talks to the PRODUCTION server.
# Must end with a trailing slash.
VITE_API_URL=https://your-prod-url/

# ─── Auth ─────────────────────────────────────────────────────────
# Keep false: prod requires a real token. true = no token sent (fake user),
# which only works against a permissive local server (none in this project).
VITE_DEV_BYPASS_AUTH=false

# Firebase web config (Firebase console → Project settings → "Your apps").
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
